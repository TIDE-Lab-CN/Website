---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import { RESEARCH_DIRECTIONS } from '../consts';

const { member } = Astro.props;
const { name, avatar, direction, email } = member.data;

const { Content } = await render(member);
const directionInfo = RESEARCH_DIRECTIONS.find(d => d.id === direction);
---

<div class="bg-white border border-slate-100 rounded-3xl overflow-hidden md:flex shadow-sm transition-all duration-500">
  <div class="md:w-1/3 lg:w-1/4 bg-slate-50 aspect-3/4 relative overflow-hidden shrink-0">
    {avatar && (
      typeof avatar === 'string' ? (
        <img src={avatar} alt={name} class="w-full h-full object-cover" />
      ) : (
       <Image
         src={avatar}
         alt={name}
         width={600}
         height={800}
         class="w-full h-full object-cover"
       />
     )
    )}
  </div>

  <div class="p-8 md:w-2/3 lg:w-3/4 flex flex-col min-w-0">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div class="flex items-center gap-3">
        <h3 class="text-2xl font-bold text-slate-900">{name}</h3>
        {directionInfo && (
          <span
            class="px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-white shadow-sm"
            style={{ backgroundColor: directionInfo.color }}
          >
            {directionInfo.label}
          </span>
        )}
      </div>
      <a
        href={`mailto:${email}`}
        class="text-slate-400 hover:text-blue-600 transition-colors text-sm font-medium"
      >
        {email}
      </a>
    </div>

    <div class="relative grow h-45">
      <div class="max-h-50 overflow-y-auto pr-4 custom-scrollbar prose prose-slate prose-sm max-w-none">
        <Content />
      </div>

      <div class="absolute bottom-0 left-0 right-0 h-8 pointer-events-none">
      </div>
    </div>
  </div>
</div>

<style is:global>
.prose p {
  margin-top: 0.5em !important;
  margin-bottom: 0.5em !important;
}

.custom-scrollbar::-webkit-scrollbar {
  width: 4px;
}

.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: #e2e8f0; /* slate-200 */
  border-radius: 10px;
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: #cbd5e1; /* slate-300 */
}
</style>
