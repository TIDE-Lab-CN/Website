---
import { Image } from 'astro:assets';
import { render } from 'astro:content';

const { member } = Astro.props;
const { name, avatar, email } = member.data;

const { Content } = await render(member);
---

<div class="overflow-hidden md:flex bg-white border border-slate-100 rounded-3xl shadow-sm duration-500 transition-all">
  <div class="overflow-hidden shrink-0 md:w-1/3 lg:w-1/4 relative bg-slate-50 aspect-3/4">
    <Image
      src={avatar}
      alt={name}
      width={600}
      height={800}
      class="object-cover h-full w-full"
    />
  </div>

  <div class="flex flex-col p-8 md:w-2/3 lg:w-3/4 min-w-0">
    <div class="flex flex-wrap gap-4 items-center justify-between mb-6">
      <div class="flex gap-3 items-center">
        <h3 class="font-bold text-2xl text-slate-900">{name}</h3>
      </div>
      <a
        href={`mailto:${email}`}
        class="font-medium text-slate-400 text-sm hover:text-blue-600 transition-colors"
      >
        {email}
      </a>
    </div>

    <div class="grow h-45 relative">
      <div class="overflow-y-auto pr-4 max-h-50 max-w-none custom-scrollbar prose prose-slate prose-sm">
        <Content />
      </div>

      <div class="h-8 absolute bottom-0 left-0 right-0 pointer-events-none">
      </div>
    </div>
  </div>
</div>

<style is:global>
.prose p {
  margin-top: 0.5em !important;
  margin-bottom: 0.5em !important;
}

.custom-scrollbar::-webkit-scrollbar {
  width: 4px;
}

.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: #e2e8f0; /* slate-200 */
  border-radius: 10px;
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: #cbd5e1; /* slate-300 */
}
</style>
