---
import { Image } from 'astro:assets';

const { member } = Astro.props;
const { name, avatar, year, major } = member.data;
---

<div class="flex flex-col items-center text-center">
  <div class="relative w-full aspect-3/4 mb-3 bg-slate-100 rounded-xl overflow-hidden border border-slate-100 shadow-sm">
    <Image
      src={avatar}
      alt={name}
      width={300}
      height={400}
      class="w-full h-full object-cover"
    />
  </div>

  <div class="space-y-1">
    <h4 class="font-bold text-slate-800 text-sm sm:text-base">{name}</h4>

    <p class="text-[11px] text-slate-500 font-medium">{year}级 · {major}</p>
  </div>
</div>
