---
import { Image } from 'astro:assets';

const { member } = Astro.props;
const { name, avatar, year, major } = member.data;
---

<div class="flex flex-col items-center text-center">
  <div class="overflow-hidden mb-3 w-full relative bg-slate-100 border border-slate-100 rounded-xl shadow-sm aspect-3/4">
    <Image
      src={avatar}
      alt={name}
      width={300}
      height={400}
      class="object-cover h-full w-full"
    />
  </div>

  <div class="space-y-1">
    <h4 class="font-bold text-slate-800 text-sm sm:text-base">{name}</h4>

    <p class="font-medium text-slate-500 text-[11px]">{year}级 · {major}</p>
  </div>
</div>
