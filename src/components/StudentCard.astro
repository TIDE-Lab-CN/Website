---
import { Image } from 'astro:assets';

interface Props {
  member: any;
}

const { member } = Astro.props;
const { name, avatar, order } = member.data;
---

<div class="flex flex-col items-center text-center group">
  <div class="relative w-full aspect-3/4 mb-4 bg-slate-100 rounded-2xl overflow-hidden border border-slate-100 shadow-sm flex items-center justify-center">
    {avatar
      ? (
        typeof avatar === 'string' ? (
          <img
            src={avatar}
            alt={name}
            class="w-full h-full object-cover object-center transition-transform duration-500"
          />
        ) : (
       <Image
         src={avatar}
         alt={name}
         width={300}
         height={400}
         class="w-full h-full object-cover object-center transition-transform duration-500"
       />
     )
      )
      : (
        <div class="flex items-center justify-center w-full h-full text-4xl font-black text-slate-300 bg-slate-100 uppercase">
          {name.charAt(0)}
        </div>
      )}
  </div>

  <div class="space-y-0.5">
    <h4 class="font-bold text-slate-800 text-sm sm:text-base transition-colors group-hover:text-blue-600">
      {name}
    </h4>
    <p class="text-[11px] text-slate-400 font-medium tracking-wider">
      {order ? `${order} 级` : ''}
    </p>
  </div>
</div>

<style>
img, :global(img) {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
</style>
