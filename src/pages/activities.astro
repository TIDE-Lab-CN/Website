---
import { getCollection } from 'astro:content';
import ImageCarousel from '../components/ImageCarousel.vue';
import { localizeDate } from '../date.ts';
import Layout from '../layouts/Layout.astro';
import { getPhotos } from '../photos.ts';

const photos = getPhotos();
const news = (await getCollection('activities'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
  <header class="mb-12">
    <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight">
      风采活动
    </h1>
    <p class="mt-4 text-slate-600 text-lg">
      探索 TIDE Lab 的科研环境与团队生活。
    </p>
  </header>

  <section class="mb-20">
    <div class="rounded-3xl overflow-hidden shadow-xl bg-slate-5 sm:aspect-21/9">
      <ImageCarousel
        client:load
        photos={photos}
        autoPlayInterval={5000}
      />
    </div>
  </section>

  <section>
    <header class="flex items-center mb-12">
      <h2 class="text-2xl font-bold text-slate-900">
        最新动态
      </h2>
      <div class="ml-4 h-px flex-1 bg-slate-100"></div>
    </header>

    <div class="divide-y divide-slate-100">
      {news.map((item) => (
        <article class="group">
          <a
            href={`/activities/${item.id}`}
            class="flex items-baseline py-5 transition-colors hover:text-blue-600"
          >
            <time
              class="w-28 shrink-0 text-sm font-medium tabular-nums text-slate-400"
            >
              {localizeDate(item.data.date)}
            </time>

            <h3 class="text-base font-medium text-slate-700 group-hover:text-blue-600 transition-colors">
              {item.data.title}
            </h3>

            <span
              class="ml-auto text-slate-300 group-hover:text-blue-400 transition-colors text-xs font-serif"
            >
            </span>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
