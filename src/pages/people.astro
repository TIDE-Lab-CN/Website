---
import { getCollection } from 'astro:content';
import FacultyCard from '../components/FacultyCard.astro';
import StudentCard from '../components/StudentCard.astro';
import Layout from '../layouts/Layout.astro';

const allMembers = await getCollection('members');

const faculty = allMembers
  .filter(m => m.data.role === 'faculty')
  .sort((a, b) => (a.data.order || 100) - (b.data.order || 100));

const students = allMembers
  .filter(m => m.data.role === 'student')
  .sort((a, b) => (a.data.order || 100) - (b.data.order || 100));

const studentsByYear = students.reduce<Record<string, any[]>>(
  (acc, student) => {
    const year = student.data.order?.toString() || 'Others';
    if (!acc[year]) acc[year] = [];
    acc[year].push(student);
    return acc;
  },
  {},
);

const years = Object.keys(studentsByYear).sort((a, b) => {
  if (a === 'Others') return 1;
  if (b === 'Others') return -1;
  return Number(b) - Number(a);
});
---

<Layout title="团队人员">
  <main class="max-w-6xl mx-auto px-4 py-16 space-y-24">
    <header class="max-w-3xl">
      <h1 class="text-4xl font-extrabold text-slate-900 mb-4">团队成员</h1>
      <p class="text-lg text-slate-600 leading-relaxed">
        TIDE Lab
        由跨学科研究者组成，致力于探索人工智能在未来医疗与工业领域的深度应用。
      </p>
    </header>

    {faculty.length > 0 && (
      <section>
        <div class="flex items-center gap-4 mb-10">
          <h2 class="text-2xl font-bold text-slate-900">指导教师</h2>
          <div class="h-px bg-slate-200 grow"></div>
        </div>
        <div class="space-y-12">
          {faculty.map((member) => <FacultyCard member={member} />)}
        </div>
      </section>
    )}

    {years.map((year) => (
      <section>
        <div class="flex items-center gap-4 mb-10">
          <h2 class="text-2xl font-bold text-slate-900">
            {year === 'Others' ? '更多成员' : `${year} 级`}
          </h2>
          <div class="h-px bg-slate-100 grow"></div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-6 gap-y-10">
          {studentsByYear[year].map((member) => (
            <StudentCard member={member} />
          ))}
        </div>
      </section>
    ))}
  </main>
</Layout>
