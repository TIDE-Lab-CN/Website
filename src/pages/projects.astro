---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
  <div class="max-w-6xl mx-auto px-6 py-12">
    <header class="mb-12 border-b border-gray-100 pb-8">
      <h1 class="text-4xl font-extrabold text-gray-900">研究成果</h1>
    </header>

    <div class="flex flex-col">
      {projects.map((proj, index) => (
        <div class="contents">
          <a
            href={`/projects/${proj.id}`}
            class="group grid grid-cols-1 md:grid-cols-12 gap-8 items-start py-10"
          >
            <div class="md:col-span-4 lg:col-span-3">
              <div class="aspect-16/10 overflow-hidden rounded-lg bg-gray-50">
                <img
                  src={proj.data.cover.src}
                  alt={proj.data.title}
                  class="w-full h-full object-cover transition-transform duration-500"
                />
              </div>
            </div>

            <div class="md:col-span-8 lg:col-span-9">
              <h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-700 transition-colors">
                {proj.data.title}
              </h2>

              <div class="flex flex-wrap gap-2 mb-4">
                {proj.data.tags.map(tag => (
                  <span
                    class="text-xs font-medium px-2 py-0.5 rounded bg-gray-100 text-gray-600"
                  >
                    {tag}
                  </span>
                ))}
              </div>

              <p class="text-gray-600 leading-relaxed text-sm line-clamp-3">
                {proj.data.abstract}
              </p>
            </div>
          </a>

          {index < projects.length - 1 && (
            <div class="border-b border-gray-100"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>
