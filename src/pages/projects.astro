---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
  <header class="pb-8 border-b border-gray-100">
    <h1 class="mb-4 font-extrabold text-4xl text-gray-900">研究成果</h1>
    <p class="leading-relaxed text-lg text-slate-600">
      TIDE Lab 成员的研究成果。
    </p>
  </header>

  <div class="flex flex-col">
    {projects.map((proj, index) => (
      <section class="contents">
        <a
          href={`/projects/${proj.id}`}
          class="gap-8 grid grid-cols-1 items-start md:grid-cols-12 py-10 group"
        >
          <div class="md:col-span-4 lg:col-span-3">
            <div class="overflow-hidden bg-gray-50 rounded-lg aspect-16/10">
              <img
                src={proj.data.cover.src}
                alt={proj.data.title}
                class="object-cover h-full w-full duration-500 transition-transform"
              />
            </div>
          </div>

          <div class="md:col-span-8 lg:col-span-9">
            <h2 class="mb-3 font-bold text-gray-900 text-xl group-hover:text-blue-700 transition-colors">
              {proj.data.title}
            </h2>

            <div class="flex flex-wrap gap-2 mb-4">
              {proj.data.tags.map(tag => (
                <span
                  class="px-2 py-0.5 font-medium text-gray-600 text-xs bg-gray-100 rounded"
                >
                  {tag}
                </span>
              ))}
            </div>

            <p class="leading-relaxed text-gray-600 text-sm line-clamp-3">
              {proj.data.abstract}
            </p>
          </div>
        </a>

        {index < projects.length - 1 && (
          <div class="border-b border-gray-100"></div>
        )}
      </section>
    ))}
  </div>
</Layout>
