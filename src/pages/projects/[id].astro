---
import { getCollection, render } from 'astro:content';
import { localizeDate } from '../../date.ts';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(item => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layout title={item.data.title} class="py-0!">
  <article class="max-w-3xl">
    <header class="mb-12 border-b border-slate-100 pb-8">
      <time class="text-sm font-mono text-blue-600 mb-3 block">
        {localizeDate(item.data.date)}
      </time>

      <h1 class="text-3xl font-bold text-slate-900 leading-snug">
        {item.data.title}
      </h1>
    </header>

    <div class="overflow-y-auto custom-scrollbar prose prose-slate prose-md max-w-none">
      <Content />
    </div>

    <footer class="mt-20 pt-8 border-t border-slate-100">
      <a
        href="/projects"
        class="group inline-flex items-center gap-1 text-slate-400 hover:text-blue-600 text-sm font-medium transition-colors"
      >
        <span class="text-xl leading-none -translate-y-px">
          &laquo;
        </span>
        <span>返回列表</span>
      </a>
    </footer>
  </article>
</Layout>
