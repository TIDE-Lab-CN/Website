---
import { getCollection, render } from 'astro:content';
import { localizeDate } from '../../date.ts';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const activities = await getCollection('activities');
  return activities.map(item => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layout title={item.data.title} class="py-0!">
  <article class="max-w-3xl">
    <header class="mb-12 pb-8 border-b border-slate-100">
      <time class="block mb-3 font-mono text-blue-600 text-sm">
        {localizeDate(item.data.date)}
      </time>

      <h1 class="font-bold leading-snug text-3xl text-slate-900">
        {item.data.title}
      </h1>
    </header>

    <div class="overflow-y-auto max-w-none custom-scrollbar prose prose-md prose-slate">
      <Content />
    </div>

    <footer class="mt-20 pt-8 border-slate-100 border-t">
      <a
        href="/activities"
        class="inline-flex gap-1 items-center font-medium text-slate-400 text-sm hover:text-blue-600 transition-colors group"
      >
        <span class="leading-none text-xl -translate-y-px">
          &laquo;
        </span>
        <span>返回列表</span>
      </a>
    </footer>
  </article>
</Layout>
